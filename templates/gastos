<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gastos</title>

<style>
body{font-family:Arial;background:#f4f6f8;padding:10px;}

.card{
background:#fff;
padding:10px;
margin:5px 0;
border-radius:8px;
font-size:12px;
}

.btn{
padding:6px;
font-size:12px;
border:none;
border-radius:5px;
color:#fff;
}

.add{background:#28a745}
.del{background:#dc3545}
</style>
</head>

<body>

<h3>💸 Controle de Gastos</h3>

<form>
<input type="month" name="mes" value="{{mes_ref}}">
<button>Filtrar</button>
</form>

<p><b>Total do mês:</b> R$ {{total}}</p>

<hr>

<form action="/add_gasto" method="post">
<input type="hidden" name="mes" value="{{mes_ref}}">

<input name="descricao" placeholder="Descrição (serviço)">
<input name="material" placeholder="Material usado">
<input name="valor" placeholder="Valor" required>

<button class="btn add">Salvar</button>
</form>

<hr>

{% for g in gastos %}
<div class="card">
<b>{{g[1] or 'Sem descrição'}}</b><br>
🧱 {{g[2] or 'Sem material'}}<br>
💰 R$ {{g[3]}}<br>
📅 {{g[4]}}

<br><br>

<a href="/del_gasto/{{g[0]}}?mes={{mes_ref}}">
<button class="btn del">Excluir</button>
</a>
</div>
{% endfor %}

<a href="/">
<button>⬅ Voltar</button>
</a>

</body>
</html>